<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Family Feud — Tournament Edition</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;600;700&family=Barlow+Condensed:wght@600;700;900&display=swap" rel="stylesheet">
<style>
/* ─── BASE ───────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#07101f; --blue:#0d1c42; --mid:#122057; --tile:#17297a;
  --gold:#f5a82a; --gold2:#ffd878; --red:#c0392b; --green:#1e9e56;
  --white:#eef2ff; --muted:rgba(238,242,255,.5);
}
html,body{height:100%;background:var(--navy);color:var(--white);font-family:'Barlow',sans-serif;overflow-x:hidden}
button{cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-weight:700;letter-spacing:.08em;border:none;transition:all .15s}

/* ─── SCREENS ────────────────────────────────────────────── */
.screen{display:none;min-height:100vh;flex-direction:column;align-items:center;justify-content:center}
.screen.active{display:flex}

/* ─── BUTTONS ────────────────────────────────────────────── */
.btn{padding:.6rem 1.5rem;border-radius:6px;font-size:1rem;text-transform:uppercase}
.btn-lg{font-size:1.25rem;padding:.85rem 2.5rem}
.btn-sm{font-size:.8rem;padding:.4rem .9rem}
.btn-gold{background:linear-gradient(135deg,var(--gold),#e0930a);color:#07101f}
.btn-gold:hover{filter:brightness(1.12);transform:translateY(-2px);box-shadow:0 6px 20px rgba(245,168,42,.4)}
.btn-outline{background:transparent;color:var(--white);border:2px solid rgba(255,255,255,.25)}
.btn-outline:hover{border-color:var(--gold);color:var(--gold)}
.btn-red{background:var(--red);color:#fff}
.btn-red:hover{background:#a72d22;transform:translateY(-2px)}
.btn-green{background:var(--green);color:#fff}
.btn-green:hover{background:#178045}
.btn-blue{background:#2563eb;color:#fff}
.btn-blue:hover{background:#1d55c9}
.btn-disabled{opacity:.35;pointer-events:none}

/* ─── SETUP SCREEN ───────────────────────────────────────── */
#s-setup{background:radial-gradient(ellipse at 50% 20%,#1a3380 0%,var(--navy) 65%)}
.setup-logo{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,9vw,6.5rem);letter-spacing:.06em;background:linear-gradient(135deg,var(--gold),var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;animation:logoPulse 3s ease-in-out infinite}
@keyframes logoPulse{0%,100%{filter:drop-shadow(0 0 12px rgba(245,168,42,.35))}50%{filter:drop-shadow(0 0 30px rgba(245,168,42,.75))}}
.setup-sub{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1rem;letter-spacing:.35em;color:var(--muted);text-transform:uppercase;margin:.4rem 0 2.5rem}
.setup-halves{display:flex;gap:2.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:2rem}
.sf-card{background:var(--blue);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:1.5rem 2rem;display:flex;flex-direction:column;align-items:center;gap:.7rem;min-width:240px}
.sf-label{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.75rem;letter-spacing:.25em;color:var(--gold);text-transform:uppercase}
.sf-card input{background:rgba(255,255,255,.07);border:2px solid rgba(245,168,42,.25);border-radius:7px;padding:.55rem 1rem;color:var(--white);font-family:'Barlow',sans-serif;font-size:1.1rem;font-weight:700;text-align:center;width:200px;transition:border-color .2s}
.sf-card input:focus{outline:none;border-color:var(--gold)}
.vs-pill{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:var(--muted);letter-spacing:.1em}

/* ─── BRACKET SCREEN ─────────────────────────────────────── */
#s-bracket{background:radial-gradient(ellipse at 50% 30%,#122057 0%,var(--navy) 70%);padding:2rem 1rem;justify-content:flex-start;padding-top:3rem}
.bracket-title{font-family:'Bebas Neue',sans-serif;font-size:2.5rem;color:var(--gold);letter-spacing:.06em;margin-bottom:2rem;text-align:center}
.bracket-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:center;width:100%;max-width:860px;margin-bottom:2.5rem}
.bracket-match{background:var(--blue);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:1.2rem 1.5rem;text-align:center}
.bracket-match.final{border-color:var(--gold);background:linear-gradient(135deg,#1a3380,#122057)}
.bm-label{font-family:'Barlow Condensed',sans-serif;font-size:.7rem;letter-spacing:.25em;color:var(--gold);text-transform:uppercase;margin-bottom:.6rem}
.bm-team{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.05rem;padding:.35rem .6rem;border-radius:5px}
.bm-team.winner{background:var(--gold);color:#07101f}
.bm-team.loser{opacity:.35}
.bm-team.tbd{opacity:.4;font-style:italic}
.bm-vs{font-size:.75rem;color:var(--muted);margin:.3rem 0}
.bracket-arrow{font-size:2rem;color:var(--gold);opacity:.5;text-align:center}
.bracket-score{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--gold2);margin-top:.4rem}
#bracket-action{text-align:center}

/* ─── MATCH SCREEN ───────────────────────────────────────── */
#s-match{display:none;flex-direction:row;min-height:100vh;padding:0}
#s-match.active{display:flex}

.team-panel{width:160px;min-width:130px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1rem .5rem;gap:.5rem;flex-shrink:0}
.team-panel.active-panel{background:rgba(245,168,42,.07)}
.tp-name{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:1.1rem;text-align:center;text-transform:uppercase;color:var(--muted);letter-spacing:.06em;word-break:break-word}
.tp-score{font-family:'Bebas Neue',sans-serif;font-size:4rem;line-height:1;color:var(--gold)}
.tp-badge{font-size:.65rem;letter-spacing:.15em;color:var(--gold);text-transform:uppercase;opacity:.8}
.tp-playing{background:var(--gold);color:#07101f;border-radius:5px;padding:.2rem .6rem;font-size:.65rem;letter-spacing:.12em;font-weight:900;text-transform:uppercase}
.tp-stealing{background:var(--red);color:#fff;border-radius:5px;padding:.2rem .6rem;font-size:.65rem;letter-spacing:.12em;font-weight:900;text-transform:uppercase}

.board-center{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1rem .5rem;min-width:0}
.board-meta{display:flex;gap:1rem;margin-bottom:.8rem;align-items:center}
.meta-tag{font-family:'Barlow Condensed',sans-serif;font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);background:rgba(255,255,255,.06);border-radius:4px;padding:.2rem .7rem}
.board-question{font-family:'Barlow Condensed',sans-serif;font-size:clamp(1rem,2.5vw,1.55rem);font-weight:700;text-align:center;max-width:680px;line-height:1.35;color:var(--white);margin-bottom:1.2rem;min-height:2.5rem}
.tiles-wrap{display:flex;flex-direction:column;gap:.65rem;width:100%;max-width:600px;margin-bottom:1rem}
.tile{display:flex;align-items:center;gap:.8rem;border-radius:8px;padding:.85rem 1.2rem;min-height:58px;border:2px solid;position:relative;overflow:hidden;transition:all .2s}
.tile.hidden{background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.12);border-style:dashed}
.tile.revealed{background:var(--tile);border-color:var(--gold);animation:tileFlip .4s ease}
@keyframes tileFlip{0%{transform:scaleY(0.1);opacity:.2}60%{transform:scaleY(1.05)}100%{transform:scaleY(1);opacity:1}}
.tile-num{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--gold);min-width:26px;text-align:center;opacity:.6}
.tile.revealed .tile-num{opacity:1}
.tile-ans{flex:1;font-family:'Barlow Condensed',sans-serif;font-size:1.2rem;font-weight:700;letter-spacing:.02em}
.tile-pts{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;color:var(--gold2);min-width:40px;text-align:right}
.tile.hidden .tile-ans,.tile.hidden .tile-pts{opacity:0}

.strikes-wrap{display:flex;gap:.6rem;justify-content:center;margin-bottom:.8rem}
.sdot{width:32px;height:32px;border-radius:50%;border:2px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:900;transition:all .3s}
.sdot.hit{background:var(--red);border-color:var(--red);animation:strikePop .4s ease}
@keyframes strikePop{0%,100%{transform:scale(1)}50%{transform:scale(1.6)}}
.status-bar{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);text-align:center;min-height:1.4rem;padding:.2rem .5rem}

/* ─── QM LINK BUTTON ─────────────────────────────────────── */
#qm-link-btn{position:fixed;top:.8rem;right:.8rem;z-index:200;background:var(--gold);color:#07101f;border-radius:6px;padding:.4rem .9rem;font-size:.8rem;letter-spacing:.15em;cursor:pointer;border:none;font-family:'Barlow Condensed',sans-serif;font-weight:700}
#qm-link-btn:hover{filter:brightness(1.1)}

/* ─── STRIKE FLASH OVERLAY ───────────────────────────────── */
#flash{position:fixed;inset:0;background:rgba(192,57,43,.2);pointer-events:none;opacity:0;z-index:100;transition:opacity .1s}
#flash.show{opacity:1}

/* ─── CHAMP SCREEN ───────────────────────────────────────── */
#s-champ{background:radial-gradient(ellipse at 50% 30%,#1a3380 0%,var(--navy) 70%);text-align:center;gap:1rem}
.champ-trophy{font-size:5rem;margin-bottom:.5rem;animation:trophyBounce 1.5s ease-in-out infinite}
@keyframes trophyBounce{0%,100%{transform:translateY(0) rotate(-5deg)}50%{transform:translateY(-15px) rotate(5deg)}}
.champ-lbl{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:.9rem;letter-spacing:.3em;color:var(--gold);text-transform:uppercase}
.champ-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(3rem,10vw,7rem);letter-spacing:.06em;background:linear-gradient(135deg,var(--gold),var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}
.champ-sub{color:var(--muted);font-size:.9rem;margin-bottom:1.5rem}

/* ─── RESPONSIVE ─────────────────────────────────────────── */
@media(max-width:640px){
  .team-panel{width:90px;min-width:70px}
  .tp-score{font-size:2.5rem}
  .tp-name{font-size:.75rem}
  .tile-ans{font-size:1rem}
  .tile-pts{font-size:1.4rem}
}
</style>
</head>
<body>

<!-- ══════════ SETUP ══════════ -->
<div class="screen active" id="s-setup">
  <div style="text-align:center;padding:2rem 1rem">
    <div class="setup-logo">FAMILY FEUD</div>
    <div class="setup-sub">Tournament Edition &nbsp;·&nbsp; 4 Families</div>
    <div class="setup-halves">
      <div class="sf-card">
        <div class="sf-label">⚡ Semi-Final 1</div>
        <input id="t0" value="Family 1" placeholder="Family 1">
        <div class="vs-pill">— VS —</div>
        <input id="t1" value="Family 2" placeholder="Family 2">
      </div>
      <div class="sf-card">
        <div class="sf-label">⚡ Semi-Final 2</div>
        <input id="t2" value="Family 3" placeholder="Family 3">
        <div class="vs-pill">— VS —</div>
        <input id="t3" value="Family 4" placeholder="Family 4">
      </div>
    </div>
    <button class="btn btn-gold btn-lg" onclick="startTournament()">START THE TOURNAMENT</button>
  </div>
</div>

<!-- ══════════ BRACKET ══════════ -->
<div class="screen" id="s-bracket">
  <div class="bracket-title">TOURNAMENT BRACKET</div>
  <div class="bracket-grid" id="bracket-grid">
    <!-- Rendered by JS -->
  </div>
  <div id="bracket-action"></div>
</div>

<!-- ══════════ MATCH BOARD (Audience View) ══════════ -->
<div class="screen" id="s-match">
  <div class="team-panel" id="panel-a">
    <div class="tp-name" id="tp-a-name">Family A</div>
    <div class="tp-score" id="tp-a-score">0</div>
    <div id="tp-a-tag"></div>
  </div>
  <div class="board-center">
    <div class="board-meta">
      <span class="meta-tag" id="meta-match">SF1</span>
      <span class="meta-tag" id="meta-round">Round 1 of 3</span>
    </div>
    <div class="board-question" id="bq">—</div>
    <div class="tiles-wrap" id="tiles"></div>
    <div class="strikes-wrap" id="strikes"></div>
    <div class="status-bar" id="status">READY</div>
  </div>
  <div class="team-panel" id="panel-b">
    <div class="tp-name" id="tp-b-name">Family B</div>
    <div class="tp-score" id="tp-b-score">0</div>
    <div id="tp-b-tag"></div>
  </div>
</div>

<!-- ══════════ CHAMPION ══════════ -->
<div class="screen" id="s-champ">
  <div class="champ-trophy">🏆</div>
  <div class="champ-lbl">Tournament Champion</div>
  <div class="champ-name" id="champ-name">—</div>
  <div class="champ-sub">Survey says… they're the BEST!</div>
  <button class="btn btn-gold btn-lg" onclick="restartAll()">PLAY AGAIN</button>
</div>

<!-- ══════════ QM LINK BUTTON ══════════ -->
<button id="qm-link-btn" onclick="window.open('family-feud-qm.html','_blank')">🎙 OPEN QM</button>

<!-- ══════════ FLASH OVERLAY ══════════ -->
<div id="flash"></div>

<script>
/* ═══════════════════════════════════════════════════════════
   QUESTION BANK  — 50 questions, TOP 3 answers each
   Format: { q: string, a: [{t: text, p: points}] }
═══════════════════════════════════════════════════════════ */
const Q_BANK = [
  {q:"Name something you might do at work to convince your boss you're too sick to be there.",a:[{t:"Cough violently",p:44},{t:"Vomit / fake throwing up",p:38},{t:"Sneeze maniacally",p:9},{t:"Lie on the desk / look pale",p:4}]},
  {q:"Name something you'd hate to find out was living in the walls of your house.",a:[{t:"Termites / bugs",p:45},{t:"Rats / mice",p:38},{t:"Snakes",p:8},{t:"Bats",p:4}]},
  {q:"Name a musical instrument perfect for someone full of hot air.",a:[{t:"Tuba",p:56},{t:"Trumpet",p:17},{t:"Trombone",p:8},{t:"Bagpipes",p:6}]},
  {q:"Name a gesture a mother would be shocked to see her baby making in an ultrasound.",a:[{t:"Flipping the bird",p:63},{t:"Waving hello",p:10},{t:"Peace sign",p:9},{t:"Thumbs down",p:7}]},
  {q:"Name a gripe about your computer you could also have about a partner.",a:[{t:"Too slow",p:68},{t:"Doesn't work / always crashing",p:20},{t:"Won't follow commands",p:5},{t:"Makes too much noise",p:3}]},
  {q:"Name a place where it's perfectly fine to sing — even if you're terrible.",a:[{t:"In the shower / bath",p:61},{t:"At church / a religious service",p:24},{t:"At a karaoke bar",p:8},{t:"In the car",p:4}]},
  {q:"Without a tongue, you couldn't lick what?",a:[{t:"Ice cream / popsicle",p:62},{t:"A lollipop",p:22},{t:"Yourself / your nose",p:7},{t:"A stamp or envelope",p:4}]},
  {q:"Name something a man takes along when shopping with his wife.",a:[{t:"Cash / wallet / credit cards",p:55},{t:"His phone / earphones",p:24},{t:"Something to read",p:13},{t:"A friend for company",p:4}]},
  {q:"Name something cats do when fighting that rival humans might also do.",a:[{t:"Scratch / claw",p:65},{t:"Screech / hiss",p:14},{t:"Bite",p:12},{t:"Pull hair",p:5}]},
  {q:"Name something an elderly person might love that's wrinkled.",a:[{t:"Their partner / spouse",p:66},{t:"Prunes / dried fruit",p:20},{t:"Old comfy clothes",p:7},{t:"Old photographs",p:4}]},
  {q:"In a crime thriller, name something the villain urgently needs to get rid of.",a:[{t:"The weapon",p:58},{t:"The body",p:26},{t:"Blood / other evidence",p:7},{t:"Witnesses",p:5}]},
  {q:"Name a reason a much younger man might marry a much older woman.",a:[{t:"She has a lot of money",p:87},{t:"He genuinely loves her",p:5},{t:"She's experienced / exciting",p:4},{t:"For a visa or citizenship",p:3}]},
  {q:"Name something a baby does that would be completely unacceptable in a flatmate.",a:[{t:"Cry / wail at 3 a.m.",p:40},{t:"Soil / wet themselves",p:28},{t:"Vomit on you",p:10},{t:"Drool on everything",p:6}]},
  {q:"Name something you love doing when you're completely alone.",a:[{t:"Reading",p:28},{t:"Watching TV / films",p:26},{t:"Taking a long bath",p:18},{t:"Dancing like nobody's watching",p:12}]},
  {q:"Name something a housefly dies from that you'd hate as your own cause of death.",a:[{t:"A flyswatter",p:74},{t:"Bug spray / insecticide",p:7},{t:"Starvation",p:6},{t:"Getting stuck on flypaper",p:4}]},
  {q:"Name something you have to squeeze really hard before anything comes out.",a:[{t:"A lemon / citrus fruit",p:28},{t:"Ketchup / mustard bottle",p:25},{t:"Toothpaste",p:20},{t:"A spot or pimple",p:14}]},
  {q:"Name something a man wears trying to impress women that actually repels them.",a:[{t:"Way too much cologne",p:64},{t:"A Speedo",p:10},{t:"A toupee / terrible wig",p:8},{t:"An unbuttoned shirt",p:6}]},
  {q:"Name something that could ruin a romantic horse-drawn carriage ride.",a:[{t:"Horse relieves itself near you",p:38},{t:"Horse has terrible gas / flatulence",p:26},{t:"Rain or a storm starts",p:12},{t:"The horse bolts or runs off",p:8}]},
  {q:"Name information you don't want but expect your best friend to tell you.",a:[{t:"Your partner is cheating",p:38},{t:"You've put on weight / look bad",p:32},{t:"You have food stuck in your teeth",p:10},{t:"You smell bad",p:8}]},
  {q:"Name an occupation where the more attractive you are, the more money you make.",a:[{t:"Exotic dancer / stripper",p:40},{t:"Model",p:26},{t:"Actor / entertainer",p:12},{t:"Salesperson",p:8}]},
  {q:"Name someone a cool teenager would be mortified to see show up at their party.",a:[{t:"Their parents",p:58},{t:"An embarrassing celebrity / person",p:12},{t:"The school nerd / geek",p:10},{t:"A teacher",p:8}]},
  {q:"If a man isn't attractive, he'd better have a beautiful ___.",a:[{t:"Personality",p:34},{t:"Smile",p:18},{t:"Heart / soul",p:18},{t:"Sense of humour",p:12}]},
  {q:"Name something you'd hate to smell when climbing into your date's car.",a:[{t:"Rubbish / old food",p:30},{t:"Cigarette / cigar smoke",p:22},{t:"Fresh flatulence",p:16},{t:"An overpowering air freshener",p:10}]},
  {q:"Name something a woman brings to bed after a tough breakup.",a:[{t:"Food / ice cream / chocolate",p:40},{t:"Her pet",p:16},{t:"A stuffed animal / teddy bear",p:12},{t:"A good book or magazine",p:8}]},
  {q:"Name something surprising grandparents might still do if they were former hippies.",a:[{t:"Smoke cannabis",p:74},{t:"Dance wildly to old music",p:8},{t:"Kiss passionately in public",p:5},{t:"Wear tie-dye or flower crowns",p:3}]},
  {q:"Name a sign your partner might secretly be turning into a cat.",a:[{t:"Meowing or purring",p:38},{t:"Clawing and scratching everything",p:22},{t:"Growing whiskers",p:18},{t:"Sleeping all day in a sunbeam",p:10}]},
  {q:"Name something a married man gets in trouble for telling others about his wife.",a:[{t:"Her weight / measurements",p:42},{t:"That she snores",p:20},{t:"Her real age",p:16},{t:"Her salary or spending habits",p:10}]},
  {q:"Name what most men would immediately do if a first date started describing her dream wedding.",a:[{t:"Run for the exit / bail",p:86},{t:"Listen politely",p:6},{t:"Smile awkwardly and say nothing",p:4},{t:"Excuse themselves to the bathroom",p:2}]},
  {q:"Name something people always seem to lose.",a:[{t:"Their keys",p:46},{t:"Their phone",p:28},{t:"Their glasses / sunglasses",p:14},{t:"Their TV remote",p:8}]},
  {q:"Name a real reason someone calls in sick when they're perfectly healthy.",a:[{t:"A hangover",p:36},{t:"Just needed a day off / laziness",p:30},{t:"Personal plans / a date",p:16},{t:"A mental health day",p:10}]},
  {q:"Name something people do in a lift / elevator when completely alone.",a:[{t:"Check their phone",p:40},{t:"Stare at themselves in the mirror",p:24},{t:"Press buttons for no reason",p:16},{t:"Talk or sing to themselves",p:10}]},
  {q:"Name something you'd definitely find on the floor of a teenager's bedroom.",a:[{t:"Clothes everywhere",p:42},{t:"Dirty dishes / snack wrappers",p:26},{t:"Charging cables and tech stuff",p:16},{t:"Empty bottles or cans",p:8}]},
  {q:"Name a reason someone might be late to their own wedding.",a:[{t:"Cold feet / last-minute nerves",p:46},{t:"Traffic / transport problems",p:22},{t:"Hair, makeup or getting ready",p:16},{t:"Can't find the ring or outfit",p:8}]},
  {q:"Name something people do when they feel extremely nervous.",a:[{t:"Sweat profusely",p:36},{t:"Bite their nails",p:26},{t:"Talk too much / ramble",p:18},{t:"Go to the toilet repeatedly",p:10}]},
  {q:"Name something you start cleaning when procrastinating on something important.",a:[{t:"The kitchen / dishes",p:34},{t:"The bathroom",p:28},{t:"Your desk or workspace",p:16},{t:"Windows or mirrors",p:10}]},
  {q:"Name something a dog does when it's overjoyed to see you come home.",a:[{t:"Wags its tail furiously",p:50},{t:"Jumps all over you",p:26},{t:"Barks or howls excitedly",p:14},{t:"Brings you a toy or gift",p:8}]},
  {q:"Name something wedding guests love to complain about.",a:[{t:"The food (not enough or bad)",p:36},{t:"The music / DJ",p:28},{t:"The seating arrangement",p:16},{t:"The speeches going on too long",p:10}]},
  {q:"Name a type of weather people complain about most.",a:[{t:"Rain",p:40},{t:"Extreme heat / humidity",p:28},{t:"Freezing cold",p:20},{t:"Gusty wind",p:8}]},
  {q:"Name something people do at a party they deeply regret the next morning.",a:[{t:"Drink way too much",p:52},{t:"Dance embarrassingly",p:20},{t:"Say something stupid to someone",p:14},{t:"Send a message they shouldn't have",p:8}]},
  {q:"Name something people do when they're bored.",a:[{t:"Scroll through their phone",p:42},{t:"Watch TV / stream something",p:26},{t:"Eat snacks",p:16},{t:"Sleep or nap",p:10}]},
