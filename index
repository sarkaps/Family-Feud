  const bq = document.getElementById('bq');
  bq.textContent = G.q ? G.q.q : '—';

  const tilesEl = document.getElementById('tiles');
  tilesEl.innerHTML = '';
  for (let i = 0; i < 4; i++) {
    const r = G.revealed[i];
    const ans = G.q ? G.q.a[i] : null;
    const div = document.createElement('div');
    div.className = 'tile ' + (r ? 'revealed' : 'hidden');
    div.innerHTML = `<span class="tile-num">${i+1}</span><span class="tile-ans">${ans ? ans.t : ''}</span><span class="tile-pts">${ans ? ans.p : ''}</span>`;
    tilesEl.appendChild(div);
  }

  const stEl = document.getElementById('strikes');
  stEl.innerHTML = '';
  for (let i = 0; i < 2; i++) {
    const d = document.createElement('div');
    d.className = 'sdot' + (i < G.strikes ? ' hit' : '');
    d.textContent = i < G.strikes ? '✗' : '';
    stEl.appendChild(d);
  }

  const sb = document.getElementById('status');
  const statusMap = {
    'select_q': '🎙 QUIZ MASTER: SELECT A QUESTION',
    'buzzer': G.bStep === 'who' ? 'BUZZER ROUND — WHO BUZZED FIRST?' :
              G.bStep === 'first_ans' ? `BUZZER — WHAT DID ${tName(G.bFirst).toUpperCase()} SAY?` :
              G.bStep === 'second_ans' ? `BUZZER — WHAT DID ${tName(opp(G.bFirst)).toUpperCase()} SAY?` :
              G.bControl ? `${tName(G.bControl).toUpperCase()} CONTROLS THE BOARD!` : 'BUZZER COMPLETE',
    'choice': G.bControl ? `${tName(G.bControl).toUpperCase()} — PLAY OR PASS?` : '',
    'playing': G.playingTeam ? `${tName(G.playingTeam).toUpperCase()} IS PLAYING!` : '',
    'steal': G.stealTeam ? `⚡ STEAL OPPORTUNITY — ${tName(G.stealTeam).toUpperCase()}!` : '',
    'award_playing': G.playingTeam ? `🏆 POINTS TO ${tName(G.playingTeam).toUpperCase()}` : '',
    'award_steal': G.stealTeam ? `🎯 STEAL! POINTS TO ${tName(G.stealTeam).toUpperCase()}` : '',
    'between_rounds': `✅ ROUND ${G.round} COMPLETE — PREPARE FOR ROUND ${G.round + 1}`,
    'match_end': `MATCH OVER — ${m.scoreA > m.scoreB ? teamA() : (m.scoreB > m.scoreA ? teamB() : 'TIE')} WINS!`,
  };
  sb.textContent = statusMap[G.phase] || '';
}

/* ═══════════════════════════════════════════════════════════
   MAIN RENDER
═══════════════════════════════════════════════════════════ */
function render() {
  if (!G.currentMatch) return;
  renderBoard();
  saveState();
}

/* ═══════════════════════════════════════════════════════════
   FLASH EFFECT
═══════════════════════════════════════════════════════════ */
function flashStrike() {
  const f = document.getElementById('flash');
  f.classList.add('show');
  setTimeout(() => f.classList.remove('show'), 280);
}
</script>
