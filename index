/* ═══════════════════════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════════════════════ */
const match  = () => G.bracket[G.currentMatch];
const teamA  = () => G.teams[match().teamA];
const teamB  = () => G.teams[match().teamB];
const tName  = (ab) => ab === 'a' ? teamA() : teamB();
const opp    = (ab) => ab === 'a' ? 'b' : 'a';
const revealedPoints = () => G.q.a.reduce((s,ans,i) => s + (G.revealed[i] ? ans.p : 0), 0);
const allRevealed    = () => G.revealed.every(Boolean);
const showScreen = (id) => {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
};

/* ═══════════════════════════════════════════════════════════
   LOCALSTORAGE SYNC
═══════════════════════════════════════════════════════════ */
function saveState() {
  try {
    const s = {...G, usedQ: [...G.usedQ]};
    localStorage.setItem('ff_state', JSON.stringify(s));
  } catch(e) {}
}

// Execute a command sent by the QM page
function handleCmd(cmd, args) {
  const handlers = {
    selectQuestion: (i)           => selectQuestion(i),
    buzzWho:        (ab)          => buzzWho(ab),
    buzzAnswer:     (idx, isSec)  => buzzAnswer(idx, isSec),
    choosePlayOrPass:(c)          => choosePlayOrPass(c),
    revealAnswer:   (i)           => revealAnswer(i),
    addStrike:      ()            => addStrike(),
    stealGuess:     (i)           => stealGuess(i),
    doAward:        ()            => doAward(),
    startNextRound: ()            => startNextRound(),
    endMatch:       ()            => endMatch(),
    setPhase:       (p)           => { G.phase = p; render(); },
    resetGame:      ()            => restartAll()
  };
  if (handlers[cmd]) handlers[cmd](...(args || []));
}

// Listen for commands from QM (storage events only fire in OTHER tabs/windows)
window.addEventListener('storage', (e) => {
  if (e.key === 'ff_cmd' && e.newValue) {
    try {
      const {cmd, args} = JSON.parse(e.newValue);
      handleCmd(cmd, args);
    } catch(err) {}
  }
});

