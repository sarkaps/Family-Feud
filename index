function startTournament() {
  G.teams = ['t0','t1','t2','t3'].map(id => document.getElementById(id).value.trim() || `Family ${id.slice(1)}`);
  G.bracket = {
    sf1: { teamA:0, teamB:1, scoreA:0, scoreB:0, winner:null },
    sf2: { teamA:2, teamB:3, scoreA:0, scoreB:0, winner:null },
    final: { teamA:null, teamB:null, scoreA:0, scoreB:0, winner:null }
  };
  G.usedQ = new Set();
  renderBracket();
  showScreen('s-bracket');
  saveState();
}

function renderBracket() {
  const bg = document.getElementById('bracket-grid');
  const ba = document.getElementById('bracket-action');
  const b = G.bracket;

  let nextMatch = null;
  if (!b.sf1.winner) nextMatch = 'sf1';
  else if (!b.sf2.winner) nextMatch = 'sf2';
  else if (b.final.teamA !== null && !b.final.winner) nextMatch = 'final';

  const matchCard = (id, label) => {
    const m = b[id];
    const na = id === 'final' ? (m.teamA !== null ? G.teams[m.teamA] : 'TBD') : G.teams[m.teamA];
    const nb = id === 'final' ? (m.teamB !== null ? G.teams[m.teamB] : 'TBD') : G.teams[m.teamB];
    const clsA = m.winner !== null ? (m.winner === m.teamA ? 'winner' : 'loser') : (m.teamA === null ? 'tbd' : '');
    const clsB = m.winner !== null ? (m.winner === m.teamB ? 'winner' : 'loser') : (m.teamB === null ? 'tbd' : '');
    const scoreStr = m.winner !== null ? `<div class="bracket-score">${m.scoreA} – ${m.scoreB}</div>` : '';
    return `<div class="bracket-match ${id==='final'?'final':''}">
      <div class="bm-label">${label}</div>
      <div class="bm-team ${clsA}">${na}</div>
      <div class="bm-vs">vs</div>
      <div class="bm-team ${clsB}">${nb}</div>
      ${scoreStr}
    </div>`;
  };

  bg.innerHTML = `
    ${matchCard('sf1','⚡ Semi-Final 1')}
    <div class="bracket-arrow">→</div>
    ${matchCard('final','🏆 FINAL')}
    <div class="bracket-arrow">←</div>
    ${matchCard('sf2','⚡ Semi-Final 2')}
  `;

  if (nextMatch) {
    const label = nextMatch === 'sf1' ? 'Start Semi-Final 1' : nextMatch === 'sf2' ? 'Start Semi-Final 2' : 'Start the FINAL!';
    ba.innerHTML = `<button class="btn btn-gold btn-lg" onclick="startMatch('${nextMatch}')">${label}</button>`;
  } else if (b.final.winner !== null) {
    ba.innerHTML = `<button class="btn btn-gold btn-lg" onclick="showChampion()">🏆 See Champion!</button>`;
  } else {
    ba.innerHTML = '';
  }
}

function startMatch(matchId) {
  G.currentMatch = matchId;
  G.round = 1;
  G.bracket[matchId].scoreA = 0;
  G.bracket[matchId].scoreB = 0;

  if (matchId === 'final') {
    G.bracket.final.teamA = G.bracket.sf1.winner;
    G.bracket.final.teamB = G.bracket.sf2.winner;
  }

  showScreen('s-match');
  G.phase = 'select_q';
  G.q = null;
  G.revealed = [false,false,false,false];
  G.strikes = 0;
  G.playingTeam = null;
  G.stealTeam = null;
  render();
}

/* ═══════════════════════════════════════════════════════════
   ROUND ACTIONS (called locally OR via QM command)
═══════════════════════════════════════════════════════════ */
function selectQuestion(qIdx) {
  G.q = Q_BANK[qIdx];
  G.usedQ.add(qIdx);
  G.revealed = [false,false,false,false];
  G.strikes = 0;
  G.playingTeam = null;
  G.stealTeam = null;
  G.phase = 'buzzer';
  G.bStep = 'who';
  G.bFirst = null;
  G.bFirstAns = null;
  G.bSecondAns = null;
  G.bControl = null;
  render();
}

function buzzWho(ab) {
  G.bFirst = ab;
  G.bStep = 'first_ans';
  render();
}

function buzzAnswer(ansIdx, isSecond = false) {
  if (!isSecond) {
    G.bFirstAns = ansIdx;
    if (ansIdx === 0) {
      G.revealed[0] = true;
      G.bControl = G.bFirst;
      G.bStep = 'done';
    } else {
      if (ansIdx >= 0) G.revealed[ansIdx] = true;
      G.bStep = 'second_ans';
    }
  } else {
    G.bSecondAns = ansIdx;
    const rank1 = G.bFirstAns;
    const rank2 = ansIdx;
    if (ansIdx >= 0) G.revealed[ansIdx] = true;

    if (rank2 === 0) {
      G.bControl = opp(G.bFirst);
    } else if (rank1 === -1 && rank2 === -1) {
      G.bControl = G.bFirst;
    } else if (rank1 === -1) {
      G.bControl = opp(G.bFirst);
    } else if (rank2 === -1) {
      G.bControl = G.bFirst;
    } else {
      G.bControl = rank2 < rank1 ? opp(G.bFirst) : G.bFirst;
    }
    G.bStep = 'done';
  }
  render();
}

function choosePlayOrPass(choice) {
  if (choice === 'play') {
    G.playingTeam = G.bControl;
  } else {
    G.playingTeam = opp(G.bControl);
  }
  G.stealTeam = opp(G.playingTeam);
  G.phase = 'playing';
  render();
}

function revealAnswer(idx) {
  if (G.revealed[idx]) return;
  G.revealed[idx] = true;
  if (allRevealed()) G.phase = 'award_playing';
  render();
}

function addStrike() {
  if (G.strikes >= 2) return;
  G.strikes++;
  flashStrike();
  if (G.strikes >= 2) {
    G.phase = 'steal';
  }
  render();
}

function stealGuess(ansIdx) {
  if (ansIdx >= 0 && !G.revealed[ansIdx]) {
    G.revealed[ansIdx] = true;
    G.phase = 'award_steal';
  } else if (ansIdx === -1) {
    G.phase = 'award_playing';
  } else {
    G.phase = 'award_playing';
  }
  render();
}

function doAward() {
  const pts = revealedPoints();
  const winner = G.phase === 'award_steal' ? G.stealTeam : G.playingTeam;
  const m = match();
  if (winner === 'a') m.scoreA += pts;
  else m.scoreB += pts;

  if (G.round < 3) {
    G.phase = 'between_rounds';
  } else {
    G.phase = 'match_end';
  }
  render();
}

function startNextRound() {
  G.round++;
  G.phase = 'select_q';
  G.q = null;
  G.revealed = [false,false,false,false];
  G.strikes = 0;
  G.playingTeam = null;
  G.stealTeam = null;
  render();
}

function endMatch() {
  const m = match();
  m.winner = m.scoreA >= m.scoreB ? m.teamA : m.teamB;
  renderBracket();

  if (G.currentMatch === 'sf1' || G.currentMatch === 'sf2') {
    const b = G.bracket;
    if (b.sf1.winner !== null && b.sf2.winner !== null) {
      b.final.teamA = b.sf1.winner;
      b.final.teamB = b.sf2.winner;
    }
  }
  saveState(); // Save before changing screen so QM sees match_end resolved
  showScreen('s-bracket');
}

function showChampion() {
  const m = G.bracket.final;
  document.getElementById('champ-name').textContent = G.teams[m.winner];
  showScreen('s-champ');
}

function restartAll() {
  localStorage.removeItem('ff_state');
  localStorage.removeItem('ff_cmd');
  showScreen('s-setup');
}

